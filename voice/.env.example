# Twilio credentials
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+18005551234

# OpenAI API key (for speech-to-text and text-to-speech)
# OPENAI_API_KEY=sk-...

# Public URL for Twilio webhooks (e.g. your server IP or ngrok URL)
# WEBHOOK_URL=https://your-server.com

# TTS voice (default: nova)
# TTS_VOICE=nova

# Override config directory (default: ~/.voice-cli)
# VOICE_CLI_HOME=/path/to/data

# API server
# BUZZIE_API_PORT=3100
# BUZZIE_API_TOKEN=your-secret-token
