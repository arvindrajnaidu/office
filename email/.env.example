# Resend API key (from resend.com/api-keys)
# RESEND_API_KEY=re_xxxxxxxxx

# Default sender email (must be on a verified domain)
# EMAIL_FROM=bot@yourdomain.com

# Override config directory (default: ~/.email-cli)
# EMAIL_CLI_HOME=/path/to/data

# LLM API keys (override config.json)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# API server
# BUZZIE_API_PORT=3100
# BUZZIE_API_TOKEN=your-secret-token
