# Telegram bot token (from @BotFather)
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Override config directory (default: ~/.telegram-cli)
# TELEGRAM_CLI_HOME=/path/to/data

# LLM API keys (override config.json)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# API server
# BUZZIE_API_PORT=3100
# BUZZIE_API_TOKEN=your-secret-token
